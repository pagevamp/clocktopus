{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Clocktopus",
  "version": "1.0.8",
  "identifier": "com.clocktopus.desktop",
  "build": {
    "frontendDist": "http://localhost:4001",
    "devUrl": "http://localhost:4001"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Clocktopus",
        "width": 420,
        "height": 600,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.icns", "icons/128x128@2x.png", "icons/128x128.png", "icons/32x32.png"],
    "macOS": {
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist"
    }
  }
}
