{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Clocktopus",
  "version": "0.1.0",
  "identifier": "com.clocktopus.app",
  "build": {
    "frontendDist": "http://localhost:4001",
    "devUrl": "http://localhost:4001"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Clocktopus",
        "width": 420,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.icns"]
  }
}
